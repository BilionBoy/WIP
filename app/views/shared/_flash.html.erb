<% if notice.present? %>
  <div class="alert alert-success alert-dismissible fade show mx-3 mt-2 shadow-sm" role="alert">
    <i class="ph-check-circle me-2"></i>
    <%= notice %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
  </div>
<% end %>

<% if alert.present? %>
  <div class="alert alert-danger alert-dismissible fade show mx-3 mt-2 shadow-sm" role="alert">
    <i class="ph-warning me-2"></i>
    <%= alert %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
  </div>
<% end %>
