<div class="text-center px-4">
  <div class="mb-4">
    <i class="ph-warning-circle" style="font-size: 5rem; color: #e65100; opacity: 0.7;"></i>
  </div>
  <h1 class="display-1 fw-bold" style="color: #e65100;">422</h1>
  <h4 class="mb-2">Requisição inválida</h4>
  <p class="text-muted mb-4">Não foi possível processar os dados enviados. Verifique as informações e tente novamente.</p>
  <%= link_to :back, class: 'btn btn-outline-secondary me-2' do %>
    <i class="ph-arrow-left me-1"></i> Voltar
  <% end %>
  <%= link_to root_path, class: 'btn btn-primary' do %>
    <i class="ph-house me-1"></i> Início
  <% end %>
</div>
