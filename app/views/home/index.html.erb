<%# Context nav / breadcrumb %>
<%= render "shared/context_nav" do %>
  <span class="breadcrumb-item active">Dashboard</span>
<% end %>

<div class="container-fluid">

  <%# Saudação %>
  <div class="mb-4">
    <h4 class="mb-0">Olá, <%= current_user.nome&.split(' ')&.first %> 👋</h4>
    <small class="text-muted"><%= l(Date.today, format: :long) %></small>
  </div>

  <%# Cards de resumo — substitua com dados reais do projeto %>
  <div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
      <div class="card card-body h-100">
        <div class="d-flex align-items-center">
          <div class="flex-fill">
            <h5 class="mb-0"><%= User.count %></h5>
            <span class="text-muted">Usuários cadastrados</span>
          </div>
          <div class="ms-3 bg-primary bg-opacity-10 rounded p-3">
            <i class="ph-users fs-2 text-primary"></i>
          </div>
        </div>
      </div>
    </div>
    <div class="col-sm-6 col-xl-3">
      <div class="card card-body h-100">
        <div class="d-flex align-items-center">
          <div class="flex-fill">
            <h5 class="mb-0">—</h5>
            <span class="text-muted">Card do projeto</span>
          </div>
          <div class="ms-3 bg-success bg-opacity-10 rounded p-3">
            <i class="ph-chart-line fs-2 text-success"></i>
          </div>
        </div>
      </div>
    </div>
    <div class="col-sm-6 col-xl-3">
      <div class="card card-body h-100">
        <div class="d-flex align-items-center">
          <div class="flex-fill">
            <h5 class="mb-0">—</h5>
            <span class="text-muted">Card do projeto</span>
          </div>
          <div class="ms-3 bg-warning bg-opacity-10 rounded p-3">
            <i class="ph-folder-open fs-2 text-warning"></i>
          </div>
        </div>
      </div>
    </div>
    <div class="col-sm-6 col-xl-3">
      <div class="card card-body h-100">
        <div class="d-flex align-items-center">
          <div class="flex-fill">
            <h5 class="mb-0">—</h5>
            <span class="text-muted">Card do projeto</span>
          </div>
          <div class="ms-3 bg-danger bg-opacity-10 rounded p-3">
            <i class="ph-bell fs-2 text-danger"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Área de conteúdo principal — substitua conforme o projeto %>
  <div class="row g-3">
    <div class="col-xl-8">
      <div class="card h-100">
        <div class="card-header">
          <h5 class="mb-0"><i class="ph-chart-bar me-2"></i>Gráfico principal</h5>
        </div>
        <div class="card-body d-flex align-items-center justify-content-center" style="min-height: 280px;">
          <div class="text-center text-muted">
            <i class="ph-chart-bar opacity-25" style="font-size: 4rem;"></i>
            <p class="mt-2">Adicione seu gráfico aqui</p>
          </div>
        </div>
      </div>
    </div>
    <div class="col-xl-4">
      <div class="card h-100">
        <div class="card-header d-flex align-items-center justify-content-between">
          <h5 class="mb-0"><i class="ph-clock-clockwise me-2"></i>Atividade recente</h5>
        </div>
        <div class="card-body">
          <div class="text-center text-muted py-4">
            <i class="ph-list-bullets opacity-25" style="font-size: 3rem;"></i>
            <p class="mt-2 mb-0">Sem registros recentes</p>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>
